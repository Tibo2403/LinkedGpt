# Public browser-safe configuration
# Do not put private API keys, OAuth client secrets, service-role keys, or passwords in VITE_* variables.
# Vite exposes VITE_* values to the browser bundle.

# Supabase public configuration
VITE_SUPABASE_URL=your_supabase_project_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key_here
VITE_DEMO_MODE=false

# Optional public OAuth client IDs only
# VITE_GOOGLE_CLIENT_ID=your_google_client_id_here
# VITE_OUTLOOK_CLIENT_ID=your_outlook_client_id_here
# VITE_LINKEDIN_CLIENT_ID=your_linkedin_client_id_here

# Private values such as OPENAI_API_KEY, GOOGLE_CLIENT_SECRET,
# OUTLOOK_CLIENT_SECRET, LINKEDIN_CLIENT_SECRET, and SUPABASE_SERVICE_ROLE_KEY
# must be stored only in a backend, serverless function, or GitHub Actions secrets.